# Copier ce fichier en .dev.vars et remplir les valeurs
# Utilisé par wrangler pages dev (npm run dev:cf)
# NE PAS committer .dev.vars (déjà dans .gitignore via *.local)

ADMIN_PWD=your_admin_password_here
ADMIN_PASSWORD=your_admin_password_here
ADMIN_PWD_MENAGE=your_menage_password_here

# ── Crons automatiques ──────────────────────────────────────────────────────
PRIX_RECAP_SECRET=un_secret_aleatoire_ici          # protège /api/send-prix-recap (cron lundi 8h)
RECAP_EMAIL=votre@email.com                        # destinataire récap prix hebdo
MENAGE_ALERT_SECRET=un_autre_secret_ici            # protège /api/send-menage-alert (cron quotidien 8h)
MENAGE_EMAIL=prestataire-menage@email.com          # destinataire alerte ménage J-2
POSTSTAY_SECRET=un_secret_ici                      # protège /api/send-poststay (cron quotidien 10h)
TOKEN_WATCH_SECRET=un_secret_ici                   # protège /api/beds24-token-watch (cron quotidien 7h)
VACANCY_ALERT_SECRET=un_secret_ici                 # protège /api/send-vacancy-alert (cron lundi 9h)

# ── Notifications ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=Amaryllis <notifications@mail.villamaryllis.com>
NOTIFICATION_EMAIL=votre@email.com

# ── Gmail (Messagerie voyageurs — chantier connecteurs 2026-07, voir docs/GMAIL-SETUP.md) ────
GOOGLE_OAUTH_CLIENT_ID=votre_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=votre_client_secret

BEDS24_API_KEY=votre_api_key_beds24
BEDS24_PROP_KEY=votre_prop_key_beds24
BEDS24_WEBHOOK_SECRET=optionnel

APPS_SCRIPT_URL=https://script.google.com/macros/s/VOTRE_ID/exec

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# iCal Airbnb
ICAL_AMARYLLIS=
ICAL_SCHOELCHER=
ICAL_GEKO=
ICAL_MABOUYA=
ICAL_IGUANA=
ICAL_ZANDOLI=
ICAL_NOGENT=

# KV binding pour cache disponibilités (optionnel - configurer dans CF Pages dashboard)
# AVAIL_CACHE=<KV namespace ID>

# iCal Booking.com
ICAL_BOOKING_AMARYLLIS=
ICAL_BOOKING_SCHOELCHER=
ICAL_BOOKING_GEKO=
ICAL_BOOKING_MABOUYA=
ICAL_BOOKING_IGUANA=
ICAL_BOOKING_ZANDOLI=
ICAL_BOOKING_NOGENT=

# Purge cache CDN manuelle (arch-011, /api/cache-purge) — optionnel, endpoint
# renvoie 503 "non configurée" si absent. Token : Cloudflare dashboard →
# My Profile → API Tokens → Create Token → permission "Zone.Cache Purge".
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
