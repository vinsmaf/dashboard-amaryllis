{
  "name": "locatif-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:cf": "wrangler pages dev --compatibility-date=2025-01-01 -- npm run dev",
    "build": "node scripts/gen-image-variants.mjs && vite build && node scripts/prerender.mjs",
    "build:skills": "node scripts/build-skills.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "visual-review": "node scripts/visual-review.mjs",
    "deploy:script": "clasp push --force",
    "deploy:worker": "wrangler deploy",
    "deploy:pages": "bash scripts/deploy-pages.sh",
    "gen:tv-screens": "node scripts/gen-tv-screens.mjs"
  },
  "dependencies": {
    "@sentry/react": "^10.53.1",
    "html-to-image": "^1.11.13",
    "leaflet": "^1.9.4",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@google/clasp": "^3.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.49.1",
    "vite": "^8.0.12",
    "vitest": "^3.2.4",
    "wrangler": "^4.92.0"
  }
}