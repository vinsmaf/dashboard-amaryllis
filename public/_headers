# Cache long terme pour les assets versionnés par Vite (hash dans le nom de fichier)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Photos — cache 7 jours
/photos/*
  Cache-Control: public, max-age=604800

# Sitemap et robots — revalidation fréquente
/sitemap.xml
  Cache-Control: public, max-age=86400

/robots.txt
  Cache-Control: public, max-age=86400

# HTML — pas de cache (version toujours fraîche)
/*.html
  Cache-Control: no-cache
