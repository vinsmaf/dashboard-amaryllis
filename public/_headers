# ── Sécurité HTTP — headers appliqués sur toutes les pages ─────────────────
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(self), payment=(self "https://js.stripe.com")
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-XSS-Protection: 1; mode=block
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://js.stripe.com https://www.googletagmanager.com https://www.google-analytics.com https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https: http:; connect-src 'self' https://api.stripe.com https://www.google-analytics.com https://analytics.google.com https://open-meteo.com https://nominatim.openstreetmap.org https://*.cloudflare.com https://api.anthropic.com; frame-src https://js.stripe.com https://hooks.stripe.com; object-src 'none'; base-uri 'self'

# ── Cache long terme pour les assets versionnés par Vite (hash dans le nom de fichier) ─
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# ── Photos — cache 7 jours ─────────────────────────────────────────────────
/photos/*
  Cache-Control: public, max-age=604800

# ── Sitemap et robots — revalidation fréquente ─────────────────────────────
/sitemap.xml
  Cache-Control: public, max-age=86400

/robots.txt
  Cache-Control: public, max-age=86400

# ── HTML — pas de cache (version toujours fraîche) ─────────────────────────
/*.html
  Cache-Control: no-cache
